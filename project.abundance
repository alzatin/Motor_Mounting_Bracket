                    "readMe": "https://raw.githubusercontent.com/BarbourSmith/Cross-Section/master/README.md?sanitize=true",
                    "yyyy": 2025,
                    "topMoleculeID": 1738702202919,
                    "githubMoleculesUsed": [],
                    "html_url": "https://github.com/BarbourSmith/Cross-Section",
                    "topics": [],
                    "parentRepo": null,
                    "forks": 0,
                    "dateModified": "739639",
                    "ranking": 6.6,
                    "searchField": "cross-section barboursmith takes a cross section of the input ",
                    "owner": "BarbourSmith",
                    "description": "Takes a cross section of the input",
                    "contentURL": "https://raw.githubusercontent.com/BarbourSmith/Cross-Section/master/project.abundance?sanitize=true",
                    "svgURL": "https://raw.githubusercontent.com/BarbourSmith/Cross-Section/master/project.svg?sanitize=true",
